{
  "name": "commentsvg",
  "version": "1.0.0",
  "description": "Cloudflare Worker that renders GitHub Discussions comments as SVG for embedding in Markdown",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.5.3",
    "wrangler": "^3.67.1"
  }
}
